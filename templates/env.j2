# DFIR-IRIS Environment Configuration
# Managed by Ansible - do not edit manually

# Nginx / reverse proxy
SERVER_NAME={{ ludus_dfir_iris_server_name }}
KEY_FILENAME={{ ludus_dfir_iris_key_filename }}
CERT_FILENAME={{ ludus_dfir_iris_cert_filename }}
INTERFACE_HTTPS_PORT={{ ludus_dfir_iris_https_port }}

# Upstream app
IRIS_UPSTREAM_SERVER=app
IRIS_UPSTREAM_PORT=8000

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD={{ ludus_dfir_iris_postgres_password }}
POSTGRES_ADMIN_USER=raptor
POSTGRES_ADMIN_PASSWORD={{ ludus_dfir_iris_postgres_admin_password }}
POSTGRES_DB=iris_db
POSTGRES_SERVER=db
POSTGRES_PORT=5432

# IRIS app
DOCKERIZED=1
IRIS_SECRET_KEY={{ ludus_dfir_iris_secret_key }}
IRIS_SECURITY_PASSWORD_SALT={{ ludus_dfir_iris_security_password_salt }}
IRIS_ADM_PASSWORD={{ ludus_dfir_iris_admin_password }}
IRIS_AUTHENTICATION_TYPE={{ ludus_dfir_iris_auth_type }}

# Worker / broker
CELERY_BROKER=amqp://rabbitmq
